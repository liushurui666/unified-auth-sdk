{
  "name": "@rc-tool/unified-auth-sdk",
  "version": "0.2.5",
  "type": "module",
  "description": "Lightweight client SDK for Unified Auth hosted services.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./providers/feishu": {
      "types": "./dist/providers/feishu.d.ts",
      "import": "./dist/providers/feishu.js"
    },
    "./redirect": {
      "types": "./dist/redirect.d.ts",
      "import": "./dist/redirect.js"
    },
    "./service-client": {
      "types": "./dist/service-client.d.ts",
      "import": "./dist/service-client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./sign-in": {
      "types": "./dist/sign-in.d.ts",
      "import": "./dist/sign-in.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --config ../../vitest.config.ts src/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "better-auth": "^1.6.10",
    "drizzle-orm": "^0.45.2 || ^1.0.0-rc.1",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
