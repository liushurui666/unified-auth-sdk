{
  "name": "@rc-tool/unified-auth-prisma-store",
  "version": "0.2.1",
  "type": "module",
  "description": "Prisma/PostgreSQL store adapter for Unified Auth hosted service.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma",
    "prisma.config.ts",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm db:generate && pnpm clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "test": "vitest run --config ../../vitest.config.ts --passWithNoTests",
    "typecheck": "pnpm db:generate && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rc-tool/unified-auth-hosted-service": "workspace:^0.2.1",
    "@rc-tool/unified-auth-sdk": "workspace:^0.2.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
